DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roommate_match?schema=public"
JWT_SECRET="replace-this-with-a-long-random-secret"
PORT=8888
# Comma-separated frontend origins for production. If omitted, all origins are
# accepted for local development.
CORS_ORIGINS="http://localhost:8081,http://localhost:19006"
# Comma-separated OAuth client IDs accepted as Google ID-token audiences.
GOOGLE_CLIENT_IDS="your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com"
